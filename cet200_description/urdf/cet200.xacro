<?xml version="1.0" encoding="utf-8"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="cet200">
  <!-- ================================================================ -->
  <!-- Macros -->
  <xacro:property name="description_pkg" value="cet200_description"/>

  <!-- Macro Sprocket -->
  <xacro:macro name="macro_sprocket" params="name:='' joint_xyz:='0 0 0' visual_rpy='0 0 0'">
    <xacro:property name="link_name" value="RB_${name}"/>

    <joint name="Hinge_${name}" type="continuous">
      <origin xyz="${joint_xyz}"  rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <parent link="RB_TrackFrame" />
      <child link="${link_name}" />
      <limit effort="38437" velocity="4.074104494" />
    </joint>

    <link name="${link_name}">
      <inertial>
        <mass value="340" />
        <origin xyz="0.0009721884578390849 0.06961311938672243 -0.00024814935669242866" rpy="0 0 0" />
        <inertia ixx="10.2047" ixy="-0.459781" ixz="2.23037e-10" iyy="6.83585" iyz="-2.9895e-11" izz="6.77422" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="${visual_rpy}" />
        <geometry>
          <mesh filename="package://${description_pkg}/meshes/sprocket.dae" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
          <cylinder length="0.05" radius="0.24"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- Macro Idler -->
  <xacro:macro name="macro_idler" params="name:='' joint_xyz:='0 0 0'">
    <xacro:property name="link_name" value="RB_${name}"/>

    <joint name="Hinge_${name}" type="continuous">
      <origin xyz="${joint_xyz}" rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <parent link="RB_TrackFrame" />
      <child link="${link_name}" />
    </joint>

    <link name="${link_name}">
      <inertial>
        <mass value="108" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="2.34497" ixy="0" ixz="0" iyy="4.27217" iyz="4.22502e-06" izz="2.345" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://${description_pkg}/meshes/idler.dae" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
          <cylinder length="0.14" radius="0.24"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- Macro Roller -->
  <xacro:macro name="macro_roller" params="name:='' joint_xyz:='0 0 0'">
    <xacro:property name="link_name" value="RB_${name}"/>

    <joint name="Hinge_${name}" type="continuous">
      <origin xyz="${joint_xyz}"  rpy="0 0 0" />
      <axis xyz="0 1 0" />
      <parent link="RB_TrackFrame" />
      <child link="${link_name}" />
    </joint>

    <link name="${link_name}">
      <inertial>
        <mass value="35" />
        <origin xyz="0 0 0" rpy="0 0 0" />
        <inertia ixx="0.181184" ixy="4.37227e-07" ixz="3.54717e-07" iyy="0.1057" iyz="0.0612396" izz="0.131501" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://${description_pkg}/meshes/roller.dae" />
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5708 0 0" />
        <geometry>
          <cylinder length="0.2144" radius="0.048"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="macro_side_wheels" params="type:='L'">
    <xacro:property name="roller_name" value="Roller_${type}"/>
    <xacro:property name="joint_y" value="1.1"/>
    <xacro:property name="sprocket_visual_rpy" value="0 0 0"/>
    <xacro:if value="${type == 'R'}">
      <xacro:property name="joint_y" value="-1.1"/>
      <xacro:property name="sprocket_visual_rpy" value="${pi} 0.0305 0"/>
    </xacro:if>

    <xacro:macro_sprocket name="Sprocket_${type}" joint_xyz="-1.6872 ${joint_y} 0.38945" visual_rpy="${sprocket_visual_rpy}"/>
    <xacro:macro_idler name="Idler_${type}" joint_xyz="1.6872 ${joint_y} 0.38945" />
    <xacro:macro_roller name="${roller_name}1" joint_xyz="0.55 ${joint_y} 0.71245" />
    <xacro:macro_roller name="${roller_name}2" joint_xyz="-0.55 ${joint_y} 0.71245" />
    <xacro:macro_roller name="${roller_name}3" joint_xyz="1.225 ${joint_y} 0.18295" />
    <xacro:macro_roller name="${roller_name}4" joint_xyz="0.825 ${joint_y} 0.18295" />
    <xacro:macro_roller name="${roller_name}5" joint_xyz="0.425 ${joint_y} 0.18295" />
    <xacro:macro_roller name="${roller_name}6" joint_xyz="0.025 ${joint_y} 0.18295" />
    <xacro:macro_roller name="${roller_name}7" joint_xyz="-0.375 ${joint_y} 0.18295" />
    <xacro:macro_roller name="${roller_name}8" joint_xyz="-0.775 ${joint_y} 0.18295" />
    <xacro:macro_roller name="${roller_name}9" joint_xyz="-1.175 ${joint_y} 0.18295" />
  </xacro:macro>

  <!-- Macro Crawler Belt -->
  <xacro:macro name="macro_crawler_belt" params="name:='' joint_xyz:='0 0 0'">
    <xacro:property name="link_name" value="dummy_RB_${name}"/>

    <joint name="dummy_LockJoint_${name}" type="fixed">
      <origin xyz="${joint_xyz}"  rpy="0 0 0" />
      <parent link="RB_TrackFrame" />
      <child link="${link_name}" />
    </joint>

    <link name="${link_name}">
      <visual>
        <geometry>
          <mesh filename="package://${description_pkg}/meshes/crawler_belt.dae" />
        </geometry>
      </visual>
    </link>
  </xacro:macro>

  <!-- ================================================================ -->

  <!-- ================================================================ -->
  <!-- Links, Joints -->
  <link name="TF_Origin" />
  <link name="base_link" />

  <joint name="dummy_LockJoint_RB_TrackFrame" type="fixed">
    <parent link="TF_Origin" />
    <child link="RB_TrackFrame" />
  </joint>

  <link name="RB_TrackFrame">
    <inertial>
      <mass value="3800" />
      <origin xyz="0.05201620740931711 1.0183557399152014e-06 0.5308690686271093" rpy="0 0 0" />
      <inertia ixx="2862.58" ixy="-0.00237404" ixz="2.47481e-05" iyy="2290.29" iyz="34.9716" izz="4857.89" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://${description_pkg}/meshes/track_frame.dae"/>
      </geometry>
    </visual>
  </link>

  <!-- Handle base_link as a dummy link. ObserverFrame in AGX -->
  <joint name="dummy_LockJoint_RB_TrackFrame_base" type="fixed">
    <parent link="RB_TrackFrame" />
    <child link="base_link" />
  </joint>

  <joint name="Hinge_Slew" type="continuous">
    <origin xyz="0 0 1"  rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <parent link="RB_TrackFrame" />
    <child link="RB_UpperStructure" />
     <limit effort="70000" velocity="1.256637061" />
  </joint>

  <link name="RB_UpperStructure">
    <inertial>
      <mass value="7600" />
      <origin xyz="-1.9067453625871538 3.5826687072582075e-07 0.5699960477872861" rpy="0 0 0" />
      <inertia ixx="6075.62" ixy="-1585.64" ixz="-1044.18" iyy="9686.21" iyz="-412.978" izz="13711.7" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://${description_pkg}/meshes/upper_structure.dae" />
      </geometry>
    </visual>
  </link>

  <joint name="Hinge_Boom" type="revolute">
    <origin xyz="0.18 0 0.83"  rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <parent link="RB_UpperStructure" />
    <child link="RB_Boom" />
    <limit effort="2009946.205" lower="-0.443" upper="1.127" velocity="0.648409027" />
  </joint>

  <link name="RB_Boom">
    <inertial>
      <mass value="1440" />
      <origin xyz="1.892940763973838 8.147612283200667e-05 2.0891289253932284" rpy="0 0 0" />
      <inertia ixx="956.006" ixy="1259.54" ixz="-0.139389" iyy="2328.5" iyz="0.0825067" izz="2913.61" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://${description_pkg}/meshes/boom.dae" />
      </geometry>
    </visual>
  </link>

  <joint name="Hinge_Arm" type="revolute">
    <origin xyz="4.71397 0 3.19445"  rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <parent link="RB_Boom" />
    <child link="RB_Arm" />
    <limit effort="300268.1523" lower="-1.40" upper="0.648" velocity="0.59757376" />
  </joint>

  <link name="RB_Arm">
    <inertial>
      <mass value="950" />
      <origin xyz="0.12784681679964738 5.671064185895034e-07 -0.9585825418396574" rpy="0 0 0" />
      <inertia ixx="818.209" ixy="-45.9014" ixz="-0.00018497" iyy="24.3643" iyz="-0.00325513" izz="809.144" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://${description_pkg}/meshes/arm.dae" />
      </geometry>
    </visual>
  </link>

  <joint name="Hinge_Bucket" type="revolute">
    <origin xyz="-0.0006 0 -2.9"  rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <parent link="RB_Arm" />
    <child link="RB_Bucket" />
    <limit effort="253122.1717" lower="-1.236" upper="1.77" velocity="0.706018147" />
  </joint>

  <link name="RB_Bucket">
    <inertial>
      <mass value="700" />
      <origin xyz="-0.01426160488025463 -2.7650072185771593e-06 -0.5611512049188314" rpy="0 0 0" />
      <inertia ixx="199.455" ixy="-0.000719484" ixz="58.3155" iyy="187.447" iyz="-0.00111114" izz="165.43" />
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://${description_pkg}/meshes/bucket.dae" />
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://${description_pkg}/meshes/collider_bucket.stl" />
      </geometry>
    </collision>
  </link>

  <xacro:macro_side_wheels type="L" />
  <xacro:macro_side_wheels type="R" />

  <xacro:macro_crawler_belt name="CrawlerBelt_L" joint_xyz="1.6872 1.09461 0.38945" />
  <xacro:macro_crawler_belt name="CrawlerBelt_R" joint_xyz="1.6872 -1.09461 0.38945" />

  <!-- Attachments -->
  <!-- TF_LidarBase -->
  <joint name="dummy_LockJoint_RB_UpperStructure_RB_LidarBase" type="fixed">
    <parent link="RB_UpperStructure" />
    <child link="TF_LidarBase" />
    <origin xyz="1.17928 0.9 2.10413"  rpy="0 ${pi/4} 0" />
    <axis xyz="0 1 0" />
  </joint>

  <link name="TF_LidarBase" />

</robot>
